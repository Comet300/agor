{
  "name": "agor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram bot that monitors Romanian classified marketplaces (OLX, AutoVit, Storia) for new listings, price drops, and stock changes.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.65",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.6.1",
    "grammy": "^1.34.0",
    "js-yaml": "^4.1.0",
    "node-html-parser": "^6.1.13",
    "pino": "^9.14.0",
    "pino-loki": "^2.6.0",
    "undici": "^6.21.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
