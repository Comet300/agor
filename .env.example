# Telegram bot token from @BotFather. Optional in test/fixture mode.
BOT_TOKEN=

# SQLite database file path.
DATABASE_PATH=./agor.db

# Comma-separated rotating residential proxy URLs (e.g. http://user:pass@host:port).
# Leave empty for direct connections (development / fixtures).
PROXY_URLS=

# Default polling cadence for a monitor (ms). 10 minutes.
DEFAULT_CHECK_INTERVAL_MS=600000

# Faster cadence used when a tracked item is out of stock (ms). 2 minutes.
OOS_FAST_INTERVAL_MS=120000

# Cross-platform dedup evaluation buffer (ms). 24 hours.
DEDUP_WINDOW_MS=86400000

# Minimum listings before a median benchmark is treated as high-confidence.
BENCHMARK_MIN_SAMPLE=4

# How long a proxy stays benched after a 429/403 before re-entering rotation (ms). 5 minutes.
PROXY_BENCH_COOLDOWN_MS=300000

# info | debug | warn | error
LOG_LEVEL=info
