# Telegram bot token from @BotFather. Optional in test/fixture mode.
BOT_TOKEN=

# SQLite database file path.
DATABASE_PATH=./agor.db

# Access control (allowlist, deny-by-default). Comma-separated Telegram chat ids
# that are seeded as admins on boot (always allowed; can /allow, /deny, /users,
# /userinfo, /setname, /setemail). OPTIONAL: if left empty, the FIRST person to
# complete /request-access is auto-approved and becomes the admin. Everyone else
# is denied until an admin allows them (they use /request-access to ask).
ADMIN_CHAT_IDS=

# Comma-separated rotating residential proxy URLs (e.g. http://user:pass@host:port).
# Leave empty for direct connections (development / fixtures).
PROXY_URLS=

# Default polling cadence for a monitor (ms). 10 minutes.
DEFAULT_CHECK_INTERVAL_MS=600000

# Faster cadence used when a tracked item is out of stock (ms). 2 minutes.
OOS_FAST_INTERVAL_MS=120000

# Cross-platform dedup evaluation buffer (ms). 24 hours.
DEDUP_WINDOW_MS=86400000

# Minimum listings before a median benchmark is treated as high-confidence.
BENCHMARK_MIN_SAMPLE=4

# How long a proxy stays benched after a 429/403 before re-entering rotation (ms). 5 minutes.
PROXY_BENCH_COOLDOWN_MS=300000

# Hard ceiling on a single monitor's poll cycle (fetch + dispatch), in ms. A cycle
# that exceeds it is abandoned so one wedged fetch/render can't starve the
# scheduler. Generous (networks + the browser fallback can be slow). 2 minutes.
MONITOR_CYCLE_TIMEOUT_MS=120000

# Consecutive blocked/failed cycles before a vendor's circuit breaker trips and
# polling for it pauses (until restart). Higher than FAILURE_ALERT_THRESHOLD:
# the user is warned early; giving up on a vendor entirely is a later decision.
CIRCUIT_BREAKER_THRESHOLD=10

# Headless-browser fallback for manifests with `fetch_strategy: browser`
# (e.g. mobile.de behind Akamai). Off by default so the base install never needs
# Chromium. Set to "true" AFTER installing the optional deps:
#   npm install playwright playwright-extra puppeteer-extra-plugin-stealth
#   npx playwright install chromium
ENABLE_BROWSER_FALLBACK=false

# trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# ── Logging → Grafana Cloud (Loki) ──────────────────────────────────────────
# Structured logs always go to stdout (captured by PM2). Set all three of the
# below to ALSO ship them to Grafana Cloud Loki. The token must be an Access
# Policy token with the `logs:write` scope (a read token returns 401).
#   LOKI_URL  — your Loki push host, e.g. https://logs-prod-039.grafana.net
#   LOKI_USER — the numeric instance/user id (Basic-auth username)
#   LOKI_TOKEN— the logs:write token (Basic-auth password)
LOKI_URL=
LOKI_USER=
LOKI_TOKEN=
LOG_SERVICE=agor
LOG_ENV=prod

# ── Update delivery ─────────────────────────────────────────────────────────
# Leave WEBHOOK_URL empty for long-polling (no public endpoint needed).
# Set it to your public HTTPS URL (e.g. a Cloudflare Tunnel hostname) to switch
# to webhook mode; the bot then listens on WEBHOOK_PORT and Telegram posts to
# WEBHOOK_URL. WEBHOOK_SECRET is a shared token Telegram echoes in a header so
# forged requests are rejected — generate one with: openssl rand -hex 32
WEBHOOK_URL=
WEBHOOK_PORT=8443
WEBHOOK_SECRET=

# Consecutive unhealthy polls before the chat is told a watch is failing.
FAILURE_ALERT_THRESHOLD=3

# How often (in scheduler ticks) to run database maintenance — a WAL checkpoint
# plus PRAGMA optimize that keep the file from slowly bloating under churn.
# The tick is the scheduler's heartbeat (~10s), so 360 ticks ≈ hourly.
DB_MAINTENANCE_INTERVAL_TICKS=360

# Liveness/readiness endpoint. In webhook mode /health rides the webhook port
# automatically and this is ignored. In long-polling mode, set a port to expose a
# tiny GET /health listener (200 when the scheduler ticked recently, 503 when
# stale). 0 disables it (default).
HEALTH_CHECK_PORT=0
