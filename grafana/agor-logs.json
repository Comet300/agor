{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Grafana Cloud Loki datasource that agor ships logs to",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "agor — poll logs",
  "tags": ["agor"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "vendor",
        "label": "Vendor",
        "type": "custom",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "query": "OLX,AutoVit,Storia,fixture",
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "OLX", "value": "OLX", "selected": false },
          { "text": "AutoVit", "value": "AutoVit", "selected": false },
          { "text": "Storia", "value": "Storia", "selected": false }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Polls (selected range)",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({service=\"agor\"} | json | component=\"cycle\" | msg=\"poll\" | vendor=~\"$vendor\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failed polls",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({service=\"agor\"} | json | component=\"cycle\" | ok=\"false\" | vendor=~\"$vendor\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Alerts sent",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({service=\"agor\"} | json | component=\"notifier\" | msg=\"alert sent\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Proxy benches (429/403)",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({service=\"agor\"} |~ \"benched\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Poll outcome",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 40, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        {
          "refId": "ok",
          "legendFormat": "ok",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({service=\"agor\"} | json | component=\"cycle\" | ok=\"true\" | vendor=~\"$vendor\" [$__interval]))"
        },
        {
          "refId": "failed",
          "legendFormat": "failed",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({service=\"agor\"} | json | component=\"cycle\" | ok=\"false\" | vendor=~\"$vendor\" [$__interval]))"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Poll duration (ms)",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "p50",
          "legendFormat": "p50",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "quantile_over_time(0.5, {service=\"agor\"} | json | component=\"cycle\" | vendor=~\"$vendor\" | unwrap durationMs [$__interval])"
        },
        {
          "refId": "p95",
          "legendFormat": "p95",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "quantile_over_time(0.95, {service=\"agor\"} | json | component=\"cycle\" | vendor=~\"$vendor\" | unwrap durationMs [$__interval])"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "New listings detected",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "new",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(sum_over_time({service=\"agor\"} | json | component=\"cycle\" | vendor=~\"$vendor\" | unwrap newItems [$__interval]))"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Items tracked (max seen / interval)",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "items",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "max(max_over_time({service=\"agor\"} | json | component=\"cycle\" | vendor=~\"$vendor\" | unwrap itemsActive [$__interval]))"
        }
      ]
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Recent failures",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service=\"agor\"} | json | ok=\"false\""
        }
      ]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Live poll stream",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service=\"agor\"} | json | component=\"cycle\" | vendor=~\"$vendor\""
        }
      ]
    }
  ]
}
